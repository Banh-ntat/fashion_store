# Sao chép thành `.env` trong thư mục backend HOẶC đặt cùng biến trong `.env` ở thư mục gốc repo (nhom333).
# Facebook: https://developers.facebook.com/ → Ứng dụng của bạn → Cài đặt → Cơ bản → App ID / App Secret

FACEBOOK_APP_ID=1571626650928827
FACEBOOK_APP_SECRET=

# Tuỳ chọn — mặc định theo FRONTEND_ORIGIN trong settings nếu không ghi
# FACEBOOK_REDIRECT_URI=http://localhost:5173/auth/facebook/callback

# --- Frontend (redirect sau thanh toán MoMo/VNPay)
# FRONTEND_ORIGIN=http://localhost:5173

# --- Thanh toán: URL công khai của backend (dùng cho redirectUrl + ipnUrl gửi lên MoMo/VNPay)
# Dev (Vite proxy /api → 8000): nên đặt rõ để redirectUrl luôn trỏ tới Django :8000, không nhầm cổng frontend.
# BACKEND_PUBLIC_BASE=http://127.0.0.1:8000
# Khi cần MoMo gọi IPN từ internet (test webhook): chạy ngrok tới cổng backend rồi:
# BACKEND_PUBLIC_BASE=https://xxxx.ngrok-free.app
# ALLOWED_HOSTS=localhost,127.0.0.1,xxxx.ngrok-free.app

# VNPay sandbox: thẻ test — https://sandbox.vnpayment.vn/apis/vnpay-demo/ — TMN riêng: https://sandbox.vnpayment.vn/devreg/
# (Code luôn dùng giờ Asia/Ho_Chi_Minh cho CreateDate/ExpireDate, kể cả khi Django TIME_ZONE=UTC.)
# VNP_TMN_CODE=2QXUI4J4
# VNP_HASH_SECRET=RAOEXHYVSDDIIENFKQSICTEFWHBWSCOU
# VNP_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# API tra cứu/hoàn tiền (querydr dùng URL này)
# VNP_API_URL=https://sandbox.vnpayment.vn/merchant_webapi/api/transaction
# Thời gian chờ thanh toán (phút), mặc định 30 — lỗi code 15 = hết hạn phiên, tăng khi test chậm
# VNP_EXPIRE_MINUTES=30
# VNPAYQR = QR (TMN sandbox demo đôi khi báo code 70 nếu không bật kênh QR); để trống = chọn trên cổng
# VNP_BANK_CODE=
# Gửi vnp_ExpireDate (một số merchant / tài liệu mới); false = giống bản zip Python chính thức
# VNP_SEND_EXPIRE_DATE=false
# (Tuỳ chọn) VNP_RETURN_PATH=/api/payments/vnpay/return/
# (Tuỳ chọn) VNP_IPN_PATH=/api/payments/vnpay/ipn/

# --- MoMo sandbox (test) — credentials mẫu công khai, chỉ dùng môi trường test
# Tài liệu: https://developers.momo.vn/ — thanh toán thử bằng app MoMo + ví test theo hướng dẫn MoMo
# MOMO_PARTNER_CODE=MOMO
# MOMO_ACCESS_KEY=F8BBA842ECF85
# MOMO_SECRET_KEY=K951B6PE1waDMi640xX08PD3vg6EkVlz
# MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
# Luồng collection link (mặc định): payWithMethod — hoặc captureWallet (ví trực tiếp)
# MOMO_REQUEST_TYPE=payWithMethod
# MOMO_AUTO_CAPTURE=true
# MOMO_ORDER_GROUP_ID=
# (Tuỳ chọn) MOMO_RETURN_PATH=/api/payments/momo/return/
# (Tuỳ chọn) MOMO_IPN_PATH=/api/payments/momo/notify/
