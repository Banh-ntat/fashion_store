DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1

# React dev server (Vite)
FRONTEND_ORIGIN=http://localhost:5173

# SQLite (mặc định khi không đặt DB_ENGINE trong .env) — không cần Postgres
DB_ENGINE=django.db.backends.sqlite3

# PostgreSQL (tạo database trước: CREATE DATABASE nt4;) — bỏ comment và xóa/comment DB_ENGINE=sqlite3 phía trên
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=nt4
# DB_USER=postgres
# DB_PASSWORD=123456
# DB_HOST=localhost
# DB_PORT=5432

# Google OAuth — trong Google Cloud Console → Authorized redirect URIs thêm đủ URI bạn dùng:
#   http://localhost:5173/auth/google/callback
#   http://127.0.0.1:5173/auth/google/callback
# GOOGLE mặc định: GOOGLE_REDIRECT_URI = FRONTEND_ORIGIN + /auth/google/callback
# GOOGLE_CLIENT_ID=your_client_id
# GOOGLE_CLIENT_SECRET=your_client_secret
# GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback

# Facebook OAuth – thêm Valid OAuth Redirect URI: http://localhost:5173/auth/facebook/callback
# FACEBOOK_APP_ID=your_app_id
# FACEBOOK_APP_SECRET=your_app_secret
# FACEBOOK_REDIRECT_URI=http://localhost:5173/auth/facebook/callback

# --- Email: quên mật khẩu (link trong mail), xác nhận đơn... ---
# Dev — in nội dung + link ra terminal (không gửi Gmail thật):
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
#
# Gmail thật — bỏ comment khối dưới và điền tài khoản:
# 1) Google Account → Bảo mật → Xác minh 2 bước
# 2) https://myaccount.google.com/apppasswords → tạo "Mật khẩu ứng dụng" cho Mail
# 3) EMAIL_HOST_USER = địa chỉ Gmail đầy đủ; EMAIL_HOST_PASSWORD = 16 ký tự (có thể bỏ dấu cách)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=tanhkhoa06@gmail.com
# EMAIL_HOST_PASSWORD=mgopcobmohcnaadf
# DEFAULT_FROM_EMAIL=FashionStore <your.email@gmail.com>
#
# Link đặt lại mật khẩu trỏ tới FRONTEND_ORIGIN (phải trùng URL bạn mở web)
# FRONTEND_ORIGIN=http://localhost:5173
# ORDER_CONFIRMATION_EMAIL_ENABLED=1
# ORDER_SHIPPED_EMAIL_ENABLED=1
# RETURN_REFUND_EMAIL_ENABLED=1
